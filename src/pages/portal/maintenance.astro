---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Report a Maintenance Issue — Nottingham Properties">
  <div class="bg-charcoal text-cream py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-cream/50 mb-3">
        <a href="/portal/dashboard" class="hover:text-cream transition-colors">Dashboard</a>
        <span>/</span>
        <span class="text-cream">Maintenance Request</span>
      </nav>
      <h1 class="font-serif text-3xl">Report a Maintenance Issue</h1>
    </div>
  </div>

  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
      <p class="text-gray-500 text-sm mb-6 leading-relaxed">
        Please describe the issue as clearly as possible. We aim to respond within 24 hours for standard requests and within 4 hours for urgent issues.
      </p>

      <form id="maintenance-form" class="space-y-5" enctype="multipart/form-data">
        <div>
          <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Issue Type *</label>
          <select name="issueType" required class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 focus:outline-none focus:border-brick transition-colors bg-white text-charcoal">
            <option value="">Select issue type...</option>
            <option>Plumbing / Water</option>
            <option>Heating / Boiler</option>
            <option>Electrical</option>
            <option>Doors / Windows / Locks</option>
            <option>Appliance</option>
            <option>Damp / Mould</option>
            <option>Pest</option>
            <option>External / Garden</option>
            <option>Other</option>
          </select>
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Urgency *</label>
          <div class="grid grid-cols-3 gap-3">
            {(['Low', 'Medium', 'Urgent'] as const).map(u => (
              <label class="flex flex-col items-center gap-2 border border-gray-200 rounded-lg p-3 cursor-pointer has-[:checked]:border-brick has-[:checked]:bg-brick/5 transition-colors">
                <input type="radio" name="urgency" value={u} class="sr-only" required />
                <span class={`w-2.5 h-2.5 rounded-full ${u === 'Low' ? 'bg-emerald-500' : u === 'Medium' ? 'bg-amber-500' : 'bg-red-500'}`}></span>
                <span class="text-sm font-medium text-charcoal">{u}</span>
              </label>
            ))}
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Description *</label>
          <textarea
            name="description"
            rows="5"
            required
            class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 focus:outline-none focus:border-brick transition-colors resize-none"
            placeholder="Please describe the issue, where in the property it is, and when it started..."
          ></textarea>
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Photos (optional)</label>
          <div class="border-2 border-dashed border-gray-200 rounded-lg p-6 text-center hover:border-brick transition-colors">
            <input type="file" name="photos" multiple accept="image/*" id="photo-upload" class="sr-only" />
            <label for="photo-upload" class="cursor-pointer">
              <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <p class="text-sm text-gray-500">Click to upload photos, or drag and drop</p>
              <p class="text-xs text-gray-400 mt-1">JPG, PNG up to 10MB each</p>
            </label>
            <p id="file-names" class="text-xs text-brick mt-2 hidden"></p>
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Best time to access property</label>
          <input
            type="text"
            name="accessTime"
            class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 focus:outline-none focus:border-brick transition-colors"
            placeholder="e.g. Weekday mornings, or after 5pm"
          />
        </div>

        <button type="submit" id="maint-submit" class="w-full bg-brick hover:bg-brick/90 text-white font-semibold py-3 rounded-lg transition-colors">
          Submit Maintenance Request
        </button>

        <div id="maint-success" class="hidden bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm rounded-lg px-4 py-3 text-center">
          Request submitted. We'll be in touch within 24 hours.
        </div>
        <div id="maint-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 text-center">
          Something went wrong. Please try again or call us on 0115 900 1234.
        </div>
      </form>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('maintenance-form') as HTMLFormElement;
  const submitBtn = document.getElementById('maint-submit') as HTMLButtonElement;
  const successEl = document.getElementById('maint-success');
  const errorEl = document.getElementById('maint-error');
  const fileInput = document.getElementById('photo-upload') as HTMLInputElement;
  const fileNames = document.getElementById('file-names');

  fileInput?.addEventListener('change', () => {
    if (!fileInput.files || !fileNames) return;
    const names = Array.from(fileInput.files).map(f => f.name).join(', ');
    fileNames.textContent = names;
    fileNames.classList.toggle('hidden', !names);
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const formData = new FormData(form);
    try {
      const res = await fetch('/api/maintenance', {
        method: 'POST',
        body: formData,
      });
      if (res.ok) {
        successEl?.classList.remove('hidden');
        form.reset();
        fileNames?.classList.add('hidden');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        errorEl?.classList.remove('hidden');
      }
    } catch {
      errorEl?.classList.remove('hidden');
    }
    submitBtn.disabled = false;
    submitBtn.textContent = 'Submit Maintenance Request';
  });
</script>
