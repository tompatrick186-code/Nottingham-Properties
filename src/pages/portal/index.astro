---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Tenant Portal — Nottingham Properties"
  description="Log in to the Nottingham Properties tenant portal to view your tenancy, raise maintenance requests, and message your landlord."
>
  <div class="min-h-screen bg-cream flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2 justify-center">
          <div class="w-9 h-9 bg-brick rounded-lg flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 18 18" fill="none">
              <path d="M9 2L2 7.5V16h5v-4h4v4h5V7.5L9 2Z" fill="white"/>
            </svg>
          </div>
          <span class="font-serif text-xl text-charcoal">
            Nottingham <span class="text-gold">Properties</span>
          </span>
        </a>
        <h1 class="font-serif text-2xl text-charcoal mt-6 mb-1">Tenant Portal</h1>
        <p class="text-gray-500 text-sm">Sign in to manage your tenancy</p>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
        <form id="login-form" class="space-y-4">
          <div>
            <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Email Address</label>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 focus:outline-none focus:border-brick transition-colors"
              placeholder="your@email.com"
            />
          </div>

          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="text-xs font-semibold text-gray-600 uppercase tracking-wide">Password</label>
              <a href="#" class="text-xs text-brick hover:underline">Forgot password?</a>
            </div>
            <input
              type="password"
              name="password"
              required
              autocomplete="current-password"
              class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 focus:outline-none focus:border-brick transition-colors"
              placeholder="••••••••"
            />
          </div>

          <button
            type="submit"
            class="w-full bg-brick hover:bg-brick/90 text-white font-semibold py-3 rounded-lg transition-colors mt-2"
          >
            Sign In
          </button>

          <div id="login-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 text-center">
            Invalid email or password. Please try again.
          </div>
        </form>

        <div class="mt-6 pt-6 border-t border-gray-100">
          <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800">
            <p class="font-semibold mb-1">Setup Required</p>
            <p class="text-xs leading-relaxed">
              This portal is powered by Supabase authentication. To enable login, create a Supabase project and add your credentials to <code class="bg-amber-100 px-1 rounded">.env</code>:
            </p>
            <ul class="text-xs mt-2 space-y-0.5 font-mono">
              <li>PUBLIC_SUPABASE_URL</li>
              <li>PUBLIC_SUPABASE_ANON_KEY</li>
            </ul>
          </div>
        </div>
      </div>

      <p class="text-center text-xs text-gray-400 mt-6">
        Not a tenant yet? <a href="/properties" class="text-brick hover:underline">Browse our properties</a>
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorEl = document.getElementById('login-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));

    // Supabase auth would go here
    // For now, redirect to dashboard with a note
    const supabaseUrl = (window as any).__SUPABASE_URL__;
    if (!supabaseUrl) {
      errorEl?.classList.remove('hidden');
      if (errorEl) errorEl.textContent = 'Portal not yet configured. Please add Supabase credentials to .env';
      return;
    }

    // Real implementation would call Supabase signInWithPassword
    window.location.href = '/portal/dashboard';
  });
</script>
