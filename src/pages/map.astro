---
import BaseLayout from '../layouts/BaseLayout.astro';
import properties from '../data/properties.json';

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;
const availableProps = properties.filter(p => p.available);
---

<BaseLayout
  title="Property Map — J & H Holdings Ltd"
  description="Browse all J & H Holdings Ltd property locations on an interactive map."
>
  <!-- Page header -->
  <div class="bg-charcoal text-cream py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between flex-wrap gap-4">
      <div>
        <p class="text-gold text-sm font-semibold uppercase tracking-wider mb-1">Explore</p>
        <h1 class="font-serif text-3xl md:text-4xl">Property Map</h1>
        <p class="text-cream/60 text-sm mt-1">{availableProps.length} properties available — click any pin for details</p>
      </div>
      <a href="/properties" class="inline-flex items-center gap-2 border border-cream/30 hover:border-cream text-cream text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
        </svg>
        List View
      </a>
    </div>
  </div>

  <!-- Map container -->
  <div class="relative">
    {mapboxToken ? (
      <div id="map" style="height: calc(100vh - 200px); min-height: 500px;"></div>
    ) : (
      <div class="flex items-center justify-center bg-stone-100 border-y border-stone-200" style="height: 500px;">
        <div class="text-center text-gray-500 max-w-sm px-4">
          <svg class="w-14 h-14 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          <h3 class="font-serif text-xl text-charcoal mb-2">Map Unavailable</h3>
          <p class="text-sm mb-4">To enable the map, add your <strong>PUBLIC_MAPBOX_TOKEN</strong> to the <code class="bg-gray-200 px-1 rounded text-xs">.env</code> file.</p>
          <a href="/properties" class="inline-flex items-center gap-2 bg-brick text-white text-sm font-semibold px-5 py-2.5 rounded-lg hover:bg-brick/90 transition-colors">
            Browse Properties List
          </a>
        </div>
      </div>
    )}

    <!-- Sidebar -->
    <div id="map-sidebar" class="absolute top-4 left-4 bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden w-64 hidden lg:block">
      <div class="bg-charcoal px-4 py-3">
        <p class="text-cream font-semibold text-sm">Available Flats</p>
      </div>
      <div class="divide-y divide-gray-100 max-h-80 overflow-y-auto">
        {properties.map(p => (
          <a
            href={`/properties/${p.id}`}
            class="flex items-start gap-3 px-4 py-3 hover:bg-cream/50 transition-colors group"
            data-id={p.id}
          >
            <div class={`w-2 h-2 rounded-full mt-1.5 flex-shrink-0 ${p.available ? 'bg-emerald-500' : 'bg-gray-400'}`}></div>
            <div>
              <p class="text-charcoal text-sm font-semibold group-hover:text-brick transition-colors leading-tight">{p.title}</p>
              <p class="text-gray-500 text-xs mt-0.5">{p.bedrooms} bed · {p.area}</p>
              {!p.available && <p class="text-gray-400 text-xs">Currently let</p>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

{mapboxToken && (
  <>
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.0.0/mapbox-gl.css" rel="stylesheet" />
  </>
)}

<script define:vars={{ properties, mapboxToken }}>
  if (mapboxToken) {
    const script = document.createElement('script');
    script.src = 'https://api.mapbox.com/mapbox-gl-js/v3.0.0/mapbox-gl.js';
    script.onload = () => {
      window.mapboxgl.accessToken = mapboxToken;
      const map = new window.mapboxgl.Map({
        container: 'map',
        style: 'mapbox://styles/mapbox/light-v11',
        center: [-1.15, 52.94],
        zoom: 12,
      });

      map.addControl(new window.mapboxgl.NavigationControl(), 'top-right');

      properties.forEach(p => {
        const popup = new window.mapboxgl.Popup({ offset: 25 }).setHTML(`
          <div style="font-family: 'DM Sans', sans-serif; padding: 4px 0;">
            <p style="font-weight: 700; font-size: 14px; color: #1A1A18; margin: 0 0 2px;">${p.title}</p>
            <p style="font-size: 13px; color: #C4490C; font-weight: 700; margin: 0 0 4px;">${p.bedrooms} bedroom · ${p.area}</p>
            <p style="font-size: 12px; color: #6b7280; margin: 0 0 8px;">${p.area}</p>
            <a href="/properties/${p.id}" style="display: inline-block; background: #C4490C; color: white; font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 6px; text-decoration: none;">View Property</a>
          </div>
        `);

        new window.mapboxgl.Marker({ color: p.available ? '#C4490C' : '#9ca3af' })
          .setLngLat([p.lng, p.lat])
          .setPopup(popup)
          .addTo(map);
      });
    };
    document.head.appendChild(script);
  }
</script>
