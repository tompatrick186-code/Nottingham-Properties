---
import BaseLayout from '../layouts/BaseLayout.astro';
import PropertyCard from '../components/PropertyCard.astro';
import properties from '../data/properties.json';

const featured = properties.slice(0, 3);
---

<BaseLayout title="J & H Holdings Ltd — Quality Homes Across Nottingham">
  <!-- Hero -->
  <section class="bg-charcoal text-cream overflow-hidden relative">
    <!-- Background texture -->
    <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 relative">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-brick/20 text-gold border border-gold/30 rounded-full px-4 py-1.5 text-sm font-medium mb-6">
          <span class="w-1.5 h-1.5 bg-gold rounded-full"></span>
          Private Landlord · Nottingham
        </div>

        <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl leading-tight mb-6">
          Quality Homes<br />
          <em class="not-italic text-gold">Across Nottingham</em>
        </h1>

        <p class="text-cream/70 text-lg leading-relaxed mb-8 max-w-xl">
          We manage a carefully curated portfolio of residential flats and apartments across Nottingham's finest neighbourhoods. No agency fees, no corporate red tape — just well-maintained homes and a landlord who picks up the phone.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/properties"
            class="inline-flex items-center justify-center gap-2 bg-brick hover:bg-brick/90 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
          >
            View Available Properties
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href="/map"
            class="inline-flex items-center justify-center gap-2 border border-cream/30 hover:border-cream text-cream font-semibold px-6 py-3 rounded-lg transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
            Browse the Map
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom curve -->
    <div class="absolute bottom-0 left-0 right-0 h-8 bg-cream" style="clip-path: ellipse(55% 100% at 50% 100%);"></div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-cream py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        <div class="group">
          <p class="font-serif text-4xl text-charcoal mb-1">50<span class="text-brick">+</span></p>
          <p class="text-gray-500 text-sm font-medium uppercase tracking-wider">Properties Managed</p>
        </div>
        <div class="group">
          <p class="font-serif text-4xl text-charcoal mb-1">20<span class="text-brick">+</span></p>
          <p class="text-gray-500 text-sm font-medium uppercase tracking-wider">Years as Landlords</p>
        </div>
        <div class="group">
          <p class="font-serif text-4xl text-charcoal mb-1">3</p>
          <p class="text-gray-500 text-sm font-medium uppercase tracking-wider">Industry Accreditations</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Properties -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-brick text-sm font-semibold uppercase tracking-wider mb-2">Currently Available</p>
          <h2 class="font-serif text-3xl md:text-4xl text-charcoal">Featured Properties</h2>
        </div>
        <a href="/properties" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-charcoal hover:text-brick transition-colors">
          View all
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featured.map(p => (
          <PropertyCard
            id={p.id}
            title={p.title}
            area={p.area}
            bedrooms={p.bedrooms}
            bathrooms={p.bathrooms}
            rent={p.rent}
            available={p.available}
            availableFrom={p.availableFrom}
            photos={p.photos}
          />
        ))}
      </div>

      <div class="text-center mt-10">
        <a
          href="/properties"
          class="inline-flex items-center gap-2 bg-charcoal hover:bg-brick text-cream font-semibold px-8 py-3 rounded-lg transition-colors"
        >
          View All Properties
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-brick text-sm font-semibold uppercase tracking-wider mb-2">Why Rent With Us</p>
        <h2 class="font-serif text-3xl md:text-4xl text-charcoal">The J & H Holdings Ltd Difference</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-brick/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brick" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl text-charcoal mb-2">Direct Landlord Access</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            No managing agents, no call centres. You deal directly with us. Maintenance issues get resolved in hours, not weeks. We answer the phone.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl text-charcoal mb-2">No Agency Fees</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            We don't charge admin fees, referencing fees or check-out fees. What you see advertised is what you pay. Deposits held in a government-approved scheme.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-charcoal/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-charcoal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl text-charcoal mb-2">Well-Maintained Homes</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Every property is professionally cleaned, PAT tested and inspected before each tenancy. We take pride in the condition of our properties — and expect tenants to as well.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 bg-charcoal text-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-gold text-sm font-semibold uppercase tracking-wider mb-2">Tenant Reviews</p>
        <h2 class="font-serif text-3xl md:text-4xl">What Our Tenants Say</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white/5 rounded-xl p-6 border border-white/10">
          <div class="text-gold text-lg mb-3">★★★★★</div>
          <p class="text-cream/80 text-sm leading-relaxed mb-4">
            "Rented from J & H Holdings Ltd for two years in the Lace Market. The flat was exactly as described, always immaculate, and any issues were sorted within 24 hours. Best renting experience I've had in the city."
          </p>
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-brick rounded-full flex items-center justify-center text-white text-xs font-bold">SH</div>
            <div>
              <p class="text-cream text-sm font-semibold">Sarah H.</p>
              <p class="text-cream/50 text-xs">Lace Market, 2024</p>
            </div>
          </div>
        </div>

        <div class="bg-white/5 rounded-xl p-6 border border-white/10">
          <div class="text-gold text-lg mb-3">★★★★★</div>
          <p class="text-cream/80 text-sm leading-relaxed mb-4">
            "Moving from London, I needed somewhere reliable quickly. The team were brilliant — responsive, professional, and completely transparent. No hidden costs, no surprises. Exactly what you want when you're relocating."
          </p>
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-gold rounded-full flex items-center justify-center text-charcoal text-xs font-bold">JM</div>
            <div>
              <p class="text-cream text-sm font-semibold">James M.</p>
              <p class="text-cream/50 text-xs">West Bridgford, 2023</p>
            </div>
          </div>
        </div>

        <div class="bg-white/5 rounded-xl p-6 border border-white/10">
          <div class="text-gold text-lg mb-3">★★★★★</div>
          <p class="text-cream/80 text-sm leading-relaxed mb-4">
            "I've rented through agencies before and the difference is night and day. Having a real person to contact — someone who knows the property inside out — makes every difference. Renewed my tenancy without hesitation."
          </p>
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-charcoal rounded-full flex items-center justify-center text-cream text-xs font-bold border border-white/20">PK</div>
            <div>
              <p class="text-cream text-sm font-semibold">Priya K.</p>
              <p class="text-cream/50 text-xs">Beeston, 2025</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-3xl md:text-4xl text-charcoal mb-4">Ready to Find Your Next Home?</h2>
      <p class="text-gray-600 text-lg mb-8 leading-relaxed">
        Browse our full portfolio of available flats across Nottingham, or get in touch and tell us what you're looking for.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/properties" class="inline-flex items-center justify-center gap-2 bg-brick hover:bg-brick/90 text-white font-semibold px-8 py-3 rounded-lg transition-colors">
          View All Properties
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-charcoal hover:bg-charcoal/90 text-cream font-semibold px-8 py-3 rounded-lg transition-colors">
          Get in Touch
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
