---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us — J & H Holdings Ltd"
  description="Get in touch with J & H Holdings Ltd. Enquire about a property, book a viewing, or ask us anything."
>
  <!-- Header -->
  <div class="bg-charcoal text-cream py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-gold text-sm font-semibold uppercase tracking-wider mb-2">We'd Love to Hear From You</p>
      <h1 class="font-serif text-3xl md:text-4xl">Get in Touch</h1>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14">
      <!-- Contact info -->
      <div>
        <h2 class="font-serif text-2xl text-charcoal mb-6">How to Reach Us</h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          We're a small private operation, which means you'll always deal with a real person. Whether you're asking about a property, chasing a maintenance request, or just want to know what's coming available — give us a call or drop us a message.
        </p>

        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-brick/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brick" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-0.5">Email</p>
              <a href="mailto:hello@jhholdings.co.uk" class="text-charcoal font-semibold hover:text-brick transition-colors">
                hello@jhholdings.co.uk
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-brick/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brick" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-0.5">Phone</p>
              <a href="tel:01159001234" class="text-charcoal font-semibold hover:text-brick transition-colors">
                0115 900 1234
              </a>
              <p class="text-xs text-gray-400 mt-0.5">Mon–Fri 9am–6pm, Sat 10am–3pm</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-brick/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brick" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-0.5">Address</p>
              <p class="text-charcoal font-semibold">J & H Holdings Ltd</p>
              <p class="text-gray-600 text-sm">PO Box 1234<br />Nottingham, NG1 1AA</p>
            </div>
          </div>
        </div>

        <!-- Response time note -->
        <div class="mt-10 bg-cream border border-gold/30 rounded-xl p-4">
          <div class="flex items-center gap-2 mb-1">
            <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
            <p class="text-sm font-semibold text-charcoal">Typically respond within a few hours</p>
          </div>
          <p class="text-xs text-gray-500">For urgent maintenance issues, existing tenants should log a request via the Tenant Portal.</p>
        </div>
      </div>

      <!-- Contact form -->
      <div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
          <h2 class="font-serif text-2xl text-charcoal mb-6">Send a Message</h2>

          <form id="contact-form" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Name *</label>
                <input type="text" name="name" required class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 focus:outline-none focus:border-brick transition-colors" placeholder="Your name" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Phone</label>
                <input type="tel" name="phone" class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 focus:outline-none focus:border-brick transition-colors" placeholder="07700 900 000" />
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Email *</label>
              <input type="email" name="email" required class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 focus:outline-none focus:border-brick transition-colors" placeholder="your@email.com" />
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Subject</label>
              <select name="subject" class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 focus:outline-none focus:border-brick transition-colors bg-white text-charcoal">
                <option>Viewing enquiry</option>
                <option>General question</option>
                <option>Application process</option>
                <option>Other</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Message *</label>
              <textarea name="message" rows="5" required class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 focus:outline-none focus:border-brick transition-colors resize-none" placeholder="Tell us what you're looking for..."></textarea>
            </div>

            <button type="submit" id="contact-submit" class="w-full bg-brick hover:bg-brick/90 text-white font-semibold py-3 rounded-lg transition-colors">
              Send Message
            </button>

            <div id="contact-success" class="hidden bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm rounded-lg px-4 py-3 text-center">
              Message sent. We'll be in touch shortly.
            </div>
            <div id="contact-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 text-center">
              Something went wrong. Please try again or call us.
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;
  const successEl = document.getElementById('contact-success');
  const errorEl = document.getElementById('contact-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    const data = Object.fromEntries(new FormData(form));
    try {
      const res = await fetch('/api/enquiry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...data, source: 'contact-page' }),
      });
      if (res.ok) {
        successEl?.classList.remove('hidden');
        form.reset();
      } else {
        errorEl?.classList.remove('hidden');
      }
    } catch {
      errorEl?.classList.remove('hidden');
    }
    submitBtn.disabled = false;
    submitBtn.textContent = 'Send Message';
  });
</script>
