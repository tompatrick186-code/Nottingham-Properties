---
import BaseLayout from '../../layouts/BaseLayout.astro';
import properties from '../../data/properties.json';

export async function getStaticPaths() {
  return properties.map(p => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const property = properties.find(p => p.id === id);

if (!property) {
  return Astro.redirect('/properties');
}

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

function bedroomLabel(n: number) {
  if (n === 0) return 'Studio';
  return `${n} Bedroom${n > 1 ? 's' : ''}`;
}
---

<BaseLayout
  title={`${property.title} — Nottingham Properties`}
  description={property.description}
>
  <!-- Breadcrumb -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-brick transition-colors">Home</a>
        <span>/</span>
        <a href="/properties" class="hover:text-brick transition-colors">Properties</a>
        <span>/</span>
        <span class="text-charcoal font-medium">{property.title}</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <!-- Left: Photos + Details -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Photo area -->
        <div class="rounded-2xl overflow-hidden bg-stone-200" style="height: 400px;">
          <div class="w-full h-full bg-gradient-to-br from-stone-300 to-stone-400 flex items-center justify-center">
            <div class="text-center text-white/60">
              <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              <p class="text-sm">Photos coming soon</p>
            </div>
          </div>
        </div>

        <!-- Header info -->
        <div>
          <div class="flex items-start justify-between flex-wrap gap-4">
            <div>
              <div class="flex items-center gap-2 mb-2">
                {property.available ? (
                  <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-700 border border-emerald-200 text-xs font-semibold px-2.5 py-1 rounded-full">
                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
                    Available
                  </span>
                ) : (
                  <span class="inline-flex items-center gap-1 bg-gray-100 text-gray-600 text-xs font-semibold px-2.5 py-1 rounded-full">
                    Currently Let
                  </span>
                )}
                <span class="text-gray-400 text-xs">{property.area}</span>
              </div>
              <h1 class="font-serif text-3xl md:text-4xl text-charcoal">{property.title}</h1>
              <p class="text-gray-500 mt-1 flex items-center gap-1.5 text-sm">
                <svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                {property.address}
              </p>
            </div>
            <div class="text-right">
              <p class="text-3xl font-bold text-brick">£{property.rent.toLocaleString()}</p>
              <p class="text-sm text-gray-500">per month</p>
              {property.availableFrom && (
                <p class="text-xs text-emerald-600 font-medium mt-1">
                  Available from {new Date(property.availableFrom).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                </p>
              )}
            </div>
          </div>

          <!-- Quick stats -->
          <div class="flex items-center gap-6 mt-5 pt-5 border-t border-gray-100">
            <div class="text-center">
              <p class="font-serif text-2xl text-charcoal">{property.bedrooms === 0 ? '—' : property.bedrooms}</p>
              <p class="text-xs text-gray-500 uppercase tracking-wide mt-0.5">{property.bedrooms === 0 ? 'Studio' : 'Beds'}</p>
            </div>
            <div class="w-px h-10 bg-gray-200"></div>
            <div class="text-center">
              <p class="font-serif text-2xl text-charcoal">{property.bathrooms}</p>
              <p class="text-xs text-gray-500 uppercase tracking-wide mt-0.5">Bath{property.bathrooms > 1 ? 'rooms' : 'room'}</p>
            </div>
            <div class="w-px h-10 bg-gray-200"></div>
            <div>
              <p class="font-semibold text-charcoal text-sm">{bedroomLabel(property.bedrooms)}</p>
              <p class="text-xs text-gray-500">Private Landlord</p>
            </div>
          </div>
        </div>

        <!-- Description -->
        <div>
          <h2 class="font-serif text-2xl text-charcoal mb-3">About This Property</h2>
          <p class="text-gray-600 leading-relaxed">{property.description}</p>
        </div>

        <!-- Features -->
        <div>
          <h2 class="font-serif text-2xl text-charcoal mb-4">Features & Amenities</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {property.features.map(f => (
              <li class="flex items-center gap-2 text-sm text-gray-700">
                <svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
        </div>

        <!-- Map -->
        <div>
          <h2 class="font-serif text-2xl text-charcoal mb-4">Location</h2>
          {mapboxToken ? (
            <div id="property-map" class="rounded-xl overflow-hidden" style="height: 300px;"></div>
          ) : (
            <div class="rounded-xl bg-stone-100 border border-stone-200 flex items-center justify-center" style="height: 300px;">
              <div class="text-center text-gray-400">
                <svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                </svg>
                <p class="text-sm">Map unavailable — add PUBLIC_MAPBOX_TOKEN to .env</p>
                <p class="text-xs mt-1">{property.address}</p>
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Right: Enquiry form -->
      <div class="lg:col-span-1">
        <div class="sticky top-24 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="bg-charcoal px-5 py-4">
            <h3 class="font-serif text-cream text-xl">Book a Viewing</h3>
            <p class="text-cream/60 text-sm mt-0.5">Usually respond within a few hours</p>
          </div>
          <form id="enquiry-form" class="px-5 py-5 space-y-4">
            <input type="hidden" name="propertyId" value={property.id} />
            <input type="hidden" name="propertyTitle" value={property.title} />

            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1">Full Name *</label>
              <input type="text" name="name" required class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 text-charcoal placeholder-gray-400 focus:outline-none focus:border-brick transition-colors" placeholder="Your name" />
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1">Email *</label>
              <input type="email" name="email" required class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 text-charcoal placeholder-gray-400 focus:outline-none focus:border-brick transition-colors" placeholder="your@email.com" />
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1">Phone</label>
              <input type="tel" name="phone" class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 text-charcoal placeholder-gray-400 focus:outline-none focus:border-brick transition-colors" placeholder="07700 900 000" />
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1">Message</label>
              <textarea name="message" rows="4" class="w-full border border-gray-200 rounded-lg text-sm px-3 py-2.5 text-charcoal placeholder-gray-400 focus:outline-none focus:border-brick transition-colors resize-none" placeholder="When are you available for a viewing? Any questions about the property?"></textarea>
            </div>

            <button
              type="submit"
              id="enquiry-submit"
              class="w-full bg-brick hover:bg-brick/90 text-white font-semibold py-3 rounded-lg transition-colors text-sm"
            >
              Send Enquiry
            </button>

            <div id="enquiry-success" class="hidden bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm rounded-lg px-4 py-3 text-center">
              Thanks! We'll be in touch shortly.
            </div>
            <div id="enquiry-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 text-center">
              Something went wrong. Please try again or call us.
            </div>
          </form>

          <div class="border-t border-gray-100 px-5 py-4 bg-gray-50">
            <p class="text-xs text-gray-500 text-center">Or call us on <a href="tel:01159001234" class="text-brick font-semibold">0115 900 1234</a></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

{mapboxToken && (
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.0.0/mapbox-gl.css" rel="stylesheet" />
)}

<script define:vars={{ lat: property.lat, lng: property.lng, title: property.title, mapboxToken }}>
  if (mapboxToken) {
    // Load Mapbox
    const script = document.createElement('script');
    script.src = 'https://api.mapbox.com/mapbox-gl-js/v3.0.0/mapbox-gl.js';
    script.onload = () => {
      window.mapboxgl.accessToken = mapboxToken;
      const map = new window.mapboxgl.Map({
        container: 'property-map',
        style: 'mapbox://styles/mapbox/light-v11',
        center: [lng, lat],
        zoom: 14,
      });
      new window.mapboxgl.Marker({ color: '#C4490C' })
        .setLngLat([lng, lat])
        .setPopup(new window.mapboxgl.Popup().setHTML(`<strong>${title}</strong>`))
        .addTo(map);
    };
    document.head.appendChild(script);
  }

  // Enquiry form
  const form = document.getElementById('enquiry-form');
  const submitBtn = document.getElementById('enquiry-submit');
  const successEl = document.getElementById('enquiry-success');
  const errorEl = document.getElementById('enquiry-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    const data = Object.fromEntries(new FormData(form));
    try {
      const res = await fetch('/api/enquiry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        successEl?.classList.remove('hidden');
        form.reset();
      } else {
        errorEl?.classList.remove('hidden');
      }
    } catch {
      errorEl?.classList.remove('hidden');
    }
    submitBtn.disabled = false;
    submitBtn.textContent = 'Send Enquiry';
  });
</script>
