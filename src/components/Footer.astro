---
const year = new Date().getFullYear();
---

<footer class="bg-charcoal text-cream/70 font-sans">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-7 h-7 bg-brick rounded flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
              <path d="M9 2L2 7.5V16h5v-4h4v4h5V7.5L9 2Z" fill="white"/>
            </svg>
          </div>
          <span class="font-serif text-cream text-base">
            J & H <span class="text-gold">Holdings Ltd</span>
          </span>
        </div>
        <p class="text-sm leading-relaxed text-cream/60 max-w-xs">
          J & H Holdings Ltd — a private landlord managing quality residential flats across Nottingham since 2014. We let properties, not experiences.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-cream text-sm font-semibold uppercase tracking-wider mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/properties" class="hover:text-gold transition-colors">Available Properties</a></li>
          <li><a href="/map" class="hover:text-gold transition-colors">Property Map</a></li>
          <li><a href="/contact" class="hover:text-gold transition-colors">Contact Us</a></li>
          <li><a href="/portal" class="hover:text-gold transition-colors">Tenant Portal</a></li>
          <li><a href="/admin" class="hover:text-gold transition-colors">Admin</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-cream text-sm font-semibold uppercase tracking-wider mb-4">Get in Touch</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:hello@jhholdings.co.uk" class="hover:text-gold transition-colors">
              hello@jhholdings.co.uk
            </a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:01159001234" class="hover:text-gold transition-colors">0115 900 1234</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="text-cream/60">Nottingham, NG1, United Kingdom</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-cream/40">
      <span>&copy; {year} J & H Holdings Ltd. All rights reserved.</span>
      <span>Registered in England &amp; Wales. ICO registered.</span>
    </div>
  </div>
</footer>
