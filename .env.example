# Mapbox — get a free token at https://mapbox.com
PUBLIC_MAPBOX_TOKEN=your_mapbox_token

# Supabase — create a project at https://supabase.com
PUBLIC_SUPABASE_URL=your_supabase_url
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Anthropic — get an API key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key

# Resend — get an API key at https://resend.com (free tier available)
RESEND_API_KEY=your_resend_key

# Admin dashboard password
ADMIN_PASSWORD=choose_a_secure_password

# Where to send enquiry and maintenance notification emails
LANDLORD_EMAIL=your@email.com
