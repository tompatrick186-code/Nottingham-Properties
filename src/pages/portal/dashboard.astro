---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Mock tenant data — in production this would come from Supabase
const tenant = {
  name: 'Sarah Johnson',
  email: 'sarah.johnson@email.com',
  property: 'Lace Market Apartment',
  address: '12 Fletcher Gate, Lace Market, Nottingham, NG1 2FZ',
  leaseStart: '2025-09-01',
  leaseEnd: '2026-08-31',
  monthlyRent: 1100,
  depositHeld: 1650,
  depositScheme: 'TDS (Tenancy Deposit Scheme)',
  nextPaymentDue: '2026-04-01',
};

const maintenanceRequests = [
  {
    id: 'MR001',
    issue: 'Kitchen tap dripping',
    submitted: '2026-03-10',
    status: 'In Progress',
    urgency: 'Low',
  },
];

const messages = [
  {
    from: 'Landlord',
    date: '2026-03-12',
    preview: 'Re: kitchen tap — plumber booked for Friday 14th between 10am–12pm.',
    read: true,
  },
];
---

<BaseLayout title="Tenant Dashboard — J & H Holdings Ltd">
  <div class="bg-charcoal text-cream py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between flex-wrap gap-4">
      <div>
        <p class="text-gold text-sm font-semibold uppercase tracking-wider mb-1">Tenant Portal</p>
        <h1 class="font-serif text-2xl md:text-3xl">Welcome back, {tenant.name.split(' ')[0]}</h1>
      </div>
      <div class="flex items-center gap-3">
        <a href="/portal/maintenance" class="inline-flex items-center gap-2 bg-brick hover:bg-brick/90 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
          </svg>
          Report Issue
        </a>
        <a href="/" class="text-cream/60 hover:text-cream text-sm transition-colors">Sign Out</a>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Tenancy overview -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="font-serif text-xl text-charcoal">Your Tenancy</h2>
            <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-700 text-xs font-semibold px-2.5 py-1 rounded-full border border-emerald-200">
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
              Active
            </span>
          </div>
          <div class="p-5">
            <div class="flex items-start gap-3 mb-5">
              <div class="w-10 h-10 bg-brick/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-brick" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-charcoal">{tenant.property}</p>
                <p class="text-gray-500 text-sm">{tenant.address}</p>
              </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
              <div class="bg-cream rounded-lg p-3">
                <p class="text-xs text-gray-500 uppercase tracking-wide mb-0.5">Monthly Rent</p>
                <p class="font-bold text-charcoal">£{tenant.monthlyRent.toLocaleString()}</p>
              </div>
              <div class="bg-cream rounded-lg p-3">
                <p class="text-xs text-gray-500 uppercase tracking-wide mb-0.5">Lease Start</p>
                <p class="font-bold text-charcoal text-sm">{new Date(tenant.leaseStart).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</p>
              </div>
              <div class="bg-cream rounded-lg p-3">
                <p class="text-xs text-gray-500 uppercase tracking-wide mb-0.5">Lease End</p>
                <p class="font-bold text-charcoal text-sm">{new Date(tenant.leaseEnd).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</p>
              </div>
              <div class="bg-cream rounded-lg p-3">
                <p class="text-xs text-gray-500 uppercase tracking-wide mb-0.5">Next Payment</p>
                <p class="font-bold text-charcoal text-sm">{new Date(tenant.nextPaymentDue).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })}</p>
              </div>
            </div>
            <div class="mt-4 text-xs text-gray-400">
              Deposit: £{tenant.depositHeld.toLocaleString()} held with {tenant.depositScheme}
            </div>
          </div>
        </div>

        <!-- Maintenance requests -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="font-serif text-xl text-charcoal">Maintenance Requests</h2>
            <a href="/portal/maintenance" class="text-brick text-sm font-semibold hover:underline">+ New Request</a>
          </div>
          <div class="divide-y divide-gray-100">
            {maintenanceRequests.length > 0 ? maintenanceRequests.map(r => (
              <div class="px-5 py-4 flex items-center justify-between gap-4">
                <div>
                  <p class="font-semibold text-charcoal text-sm">{r.issue}</p>
                  <p class="text-gray-400 text-xs mt-0.5">
                    #{r.id} · Submitted {new Date(r.submitted).toLocaleDateString('en-GB', { day: 'numeric', month: 'long' })} · {r.urgency} priority
                  </p>
                </div>
                <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full whitespace-nowrap ${
                  r.status === 'In Progress' ? 'bg-amber-50 text-amber-700 border border-amber-200' :
                  r.status === 'Resolved' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' :
                  'bg-gray-100 text-gray-600 border border-gray-200'
                }`}>
                  {r.status}
                </span>
              </div>
            )) : (
              <div class="px-5 py-8 text-center text-gray-400 text-sm">
                No open maintenance requests.
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-5">
        <!-- Messages -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-5 py-4 border-b border-gray-100">
            <h2 class="font-serif text-lg text-charcoal">Messages</h2>
          </div>
          <div class="divide-y divide-gray-100">
            {messages.map(m => (
              <div class="px-5 py-3">
                <div class="flex items-start justify-between gap-2">
                  <p class="text-sm font-semibold text-charcoal">{m.from}</p>
                  <p class="text-xs text-gray-400">{new Date(m.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })}</p>
                </div>
                <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">{m.preview}</p>
              </div>
            ))}
          </div>
          <div class="px-5 py-3 border-t border-gray-100">
            <a href="mailto:hello@jhholdings.co.uk" class="text-brick text-xs font-semibold hover:underline">
              Message landlord
            </a>
          </div>
        </div>

        <!-- Quick actions -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-5 py-4 border-b border-gray-100">
            <h2 class="font-serif text-lg text-charcoal">Quick Actions</h2>
          </div>
          <div class="p-4 space-y-2">
            <a href="/portal/maintenance" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-cream transition-colors text-sm text-charcoal font-medium">
              <svg class="w-4 h-4 text-brick" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
              </svg>
              Report a maintenance issue
            </a>
            <a href="mailto:hello@jhholdings.co.uk" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-cream transition-colors text-sm text-charcoal font-medium">
              <svg class="w-4 h-4 text-brick" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Email the landlord
            </a>
            <a href="tel:01159001234" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-cream transition-colors text-sm text-charcoal font-medium">
              <svg class="w-4 h-4 text-brick" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              Call 0115 900 1234
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
