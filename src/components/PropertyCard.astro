---
interface Props {
  id: string;
  title: string;
  area: string;
  bedrooms: number;
  bathrooms: number;
  available: boolean;
  availableFrom: string | null;
  photos?: string[];
  address?: string;
}

const { id, title, area, bedrooms, bathrooms, available, availableFrom, photos, address } = Astro.props;

const gradients = [
  'from-stone-300 to-stone-400',
  'from-slate-300 to-slate-400',
  'from-zinc-300 to-zinc-400',
];
const gradient = gradients[Math.abs(id.charCodeAt(0) + id.charCodeAt(5)) % gradients.length];

function bedroomLabel(n: number) {
  if (n === 0) return 'Studio';
  return `${n} Bed`;
}

function formatDate(d: string | null) {
  if (!d) return null;
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<article class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-100 group">
  <!-- Photo area -->
  <a href={`/properties/${id}`} class="block relative overflow-hidden" style="height: 200px;">
    {photos && photos.length > 0 ? (
      <img
        src={photos[0]}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
    ) : null}
    <!-- Placeholder gradient -->
    <div
      class={`absolute inset-0 bg-gradient-to-br ${gradient} flex items-center justify-center ${photos && photos.length > 0 ? 'hidden' : 'flex'}`}
      id={`placeholder-${id}`}
    >
      <svg class="w-12 h-12 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
    </div>

    <!-- Badge -->
    <div class="absolute top-3 left-3">
      {available ? (
        <span class="inline-flex items-center gap-1 bg-emerald-600 text-white text-xs font-semibold px-2.5 py-1 rounded-full">
          <span class="w-1.5 h-1.5 bg-white rounded-full"></span>
          Available
        </span>
      ) : (
        <span class="inline-flex items-center gap-1 bg-gray-700 text-white text-xs font-semibold px-2.5 py-1 rounded-full">
          Let
        </span>
      )}
    </div>
  </a>

  <!-- Content -->
  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-1">
      <h3 class="font-serif text-charcoal text-lg leading-snug group-hover:text-brick transition-colors">
        <a href={`/properties/${id}`}>{title}</a>
      </h3>
    </div>

    <p class="text-sm text-gray-500 mb-3 flex items-center gap-1">
      <svg class="w-3.5 h-3.5 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      {area}
    </p>

    <div class="flex items-center gap-4 text-sm text-gray-600 mb-4">
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        {bedroomLabel(bedrooms)}
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
        </svg>
        {bathrooms} Bath
      </span>
      {available && availableFrom && (
        <span class="text-emerald-600 text-xs font-medium">
          From {formatDate(availableFrom)}
        </span>
      )}
    </div>

    <a
      href={`/properties/${id}`}
      class="block w-full text-center bg-charcoal hover:bg-brick text-cream text-sm font-semibold py-2.5 rounded-lg transition-colors"
    >
      View Property
    </a>
  </div>
</article>
